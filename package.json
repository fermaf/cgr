    "agents:ingest:scan": "npm run agents:build -- --pretty false && node ./.agents-dist/agents/examples/runIngestTopologyScan.js",
    "agents:convergence:report": "npm run agents:build -- --pretty false && node ./.agents-dist/agents/examples/runCapabilityConvergenceReport.js",
