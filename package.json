    "agents:ingest:native-incident": "npm run agents:build -- --pretty false && node ./.agents-dist/agents/examples/runIngestNativeIncident.js",
    "agents:ingest:native-router": "npm run agents:build -- --pretty false && node ./.agents-dist/agents/examples/runIngestNativeRouter.js",
    "agents:ingest:route-adapter": "npm run agents:build -- --pretty false && node ./.agents-dist/agents/examples/runIngestRouteAdapter.js"
